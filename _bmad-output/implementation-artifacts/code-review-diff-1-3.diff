@@ -0,0 +1,39 @@
+export class ApiError extends Error {
+  readonly code: string;
+
+  constructor(code: string, message: string) {
+    super(message);
+    this.name = "ApiError";
+    this.code = code;
+  }
+}
+
+export async function apiFetch<T>(
+  path: string,
+  options?: RequestInit & { redirectOn401?: boolean },
+): Promise<T> {
+  const { redirectOn401 = true, ...fetchOptions } = options ?? {};
+  const res = await fetch(path, { credentials: "include", ...fetchOptions });
+  if (res.status === 401) {
+    const errBody = (await res.json().catch(() => null)) as {
+      error?: { code: string; message: string };
+    } | null;
+    if (redirectOn401) window.location.href = "/login";
+    throw new ApiError(
+      errBody?.error?.code ?? "AUTH_UNAUTHORIZED",
+      errBody?.error?.message ?? "Not authenticated",
+    );
+  }
+  const body = (await res.json()) as {
+    success: boolean;
+    data?: T;
+    error?: { code: string; message: string };
+  };
+  if (!body.success) {
+    throw new ApiError(
+      body.error?.code ?? "UNKNOWN_ERROR",
+      body.error?.message ?? "Unknown error",
+    );
+  }
+  return body.data as T;
+}
