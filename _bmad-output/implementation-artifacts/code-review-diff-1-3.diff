+  align-items: center;
+  justify-content: center;
+  width: 32px;
+  height: 32px;
+  border-radius: var(--radius-full);
+  border: none;
+  background: var(--brand);
+  color: var(--brand-fg);
+  cursor: pointer;
+  font-size: 0.6875rem;
+  font-weight: 700;
