# =============================================================================
# Fishtank — root .gitignore
# Covers: .NET 10, React/Vite/TypeScript, Docker, IDE, OS
# =============================================================================

# =============================================================================
# .NET / C#
# =============================================================================

# Build output
[Bb]in/
[Oo]bj/
out/

# NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/[Pp]ackages/repositories.config

# Visual Studio / MSBuild artifacts
*.user
*.userosscache
*.sln.docstates
*.suo
*.userprefs
.vs/
.msbuildcache/

# Publish output
[Pp]ublish/
[Pp]ublish[Oo]utput/
PublishScripts/

# Entity Framework migrations designer snapshots (keep migrations, drop IDE backups)
*.orig

# Test results & coverage
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
coverage*/
*.coverage
*.coveragexml
*.trx
*.xml.bak

# Crash dumps
*.dmp

# Secrets / local settings (never commit real secrets)
appsettings.Local.json
appsettings.*.Local.json
secrets.json
.secrets

# .NET tools manifest (project-local tools — keep .config/dotnet-tools.json)
# EF Core design-time output (safe to regenerate)
efpt.*.json

# =============================================================================
# Node / npm / Frontend
# =============================================================================

node_modules/
.npm/
.pnpm-store/

# Build output
src/client/dist/
src/client/dist-ssr/
src/Fishtank.Api/wwwroot/*
!src/Fishtank.Api/wwwroot/.gitkeep
src/client/.vite/

# Vite cache
src/client/.vite/

# TypeScript incremental build info
*.tsbuildinfo

# Coverage
src/client/coverage/
lcov.info
*.lcov

# MSW generated service worker (regenerated by CLI)
src/client/public/mockServiceWorker.js

# Test artefacts
src/client/test-results/
src/client/playwright-report/
src/client/blob-report/
src/client/playwright/.cache/
src/client/playwright/.auth/

# Storybook
storybook-static/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# local env overrides — keep .env.example, ignore actuals with secrets
.env
.env.local
.env.*.local
!.env.example
!.env.test

# =============================================================================
# Docker
# =============================================================================

# Ignore local override compose files (keep docker-compose.yml and docker-compose.example.yml)
docker-compose.override.yml
docker-compose.local.yml

# =============================================================================
# Database files
# =============================================================================

*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
fishtank.db*

# =============================================================================
# Logs & diagnostics
# =============================================================================

logs/
*.log
Logs/

# =============================================================================
# IDE — Visual Studio Code
# =============================================================================

.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
!.vscode/settings.json

# =============================================================================
# IDE — JetBrains (Rider)
# =============================================================================

.idea/
*.sln.iml

# =============================================================================
# IDE — Visual Studio / Node Tools for Visual Studio
# =============================================================================

*.aps
*.ncb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
ServiceFabricBackup/
*.ntvs*
*.njsproj

# =============================================================================
# Editor swap / temp files
# =============================================================================

# Vim
*.sw?

# Local overrides (Vite, editor, etc.)
*.local
!.env.example

# =============================================================================
# OS artefacts
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# =============================================================================
# Misc tooling
# =============================================================================

# Playwright (if added later — E2E test artefacts)
test-results/
playwright-report/
blob-report/

# Vitest UI cache
.vitest-cache/

# ESLint cache
.eslintcache

# Prettier cache
.prettiercache

# SWC / Turbo
.turbo/
.swc/

# =============================================================================
# Support Tool (support/tools/fishtank-helper-tool/)
# =============================================================================

# Python virtual environment — created by option [2] Install / update dependencies
support/tools/fishtank-helper-tool/.venv/

# Local environment variables — copy .env.example → .env; never commit real values
support/tools/fishtank-helper-tool/.env

# Python bytecode cache
support/tools/fishtank-helper-tool/__pycache__/
support/tools/fishtank-helper-tool/**/__pycache__/
support/tools/fishtank-helper-tool/.pytest_cache/
support/tools/fishtank-helper-tool/**/.pytest_cache/

# Runtime volume data — written by Docker at runtime, not part of source
support/tools/fishtank-helper-tool/data/*
!support/tools/fishtank-helper-tool/data/.gitkeep
support/tools/fishtank-helper-tool/mocks/*
!support/tools/fishtank-helper-tool/mocks/.gitkeep
