# Fishtank Support Tool — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit real values.

# ─── Container port ──────────────────────────────────────────────────────────
# Fishtank management port exposed on the host (maps to container port 5000)
FISHTANK_PORT=5000

# ─── Volume mounts ───────────────────────────────────────────────────────────
# Absolute path on the HOST (Windows or WSL) to the mocks folder.
# WSL path example:     /mnt/c/projects/fishtank-mocks
# Windows path example: C:\projects\fishtank-mocks  (tool auto-converts to WSL)
FISHTANK_MOCKS_PATH=./mocks

# Absolute path on the HOST to the Fishtank data directory (SQLite DB lives here)
FISHTANK_DATA_PATH=./data

# ─── Auth ────────────────────────────────────────────────────────────────────
# Admin password for first-run setup. If unset, the first login forces a
# password-change via the first-run setup screen.
# FISHTANK_ADMIN_PASSWORD=

# ─── JWT settings ────────────────────────────────────────────────────────────
# JWT expiry in minutes. Default: container lifetime (session cookie behaviour).
# FISHTANK_JWT_EXPIRY_MINUTES=
