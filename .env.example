# =============================================================================
# Fishtank — .env.example
# Copy to .env and fill in real values. Never commit .env.
# =============================================================================

# --- Test environment --------------------------------------------------------
# Which environment to target when running E2E tests.
# Supported values: local
TEST_ENV=local

# Base URL of the running Vite dev server (frontend)
BASE_URL=http://localhost:5173

# Base URL of the running .NET API (backend)
# Port matches launchSettings.json http profile (http://localhost:5190)
API_URL=http://localhost:5190

# --- Test credentials --------------------------------------------------------
# Default test user (read-only / regular role)
TEST_USER=admin
TEST_PASS=admin

# Admin test user (full access)
TEST_ADMIN_USER=admin
TEST_ADMIN_PASS=admin

# --- Debug flags -------------------------------------------------------------
# Set to "true" to enable verbose auth-session logging
DEBUG_AUTH=false
