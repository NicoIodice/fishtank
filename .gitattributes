# Fishtank .gitattributes
# Enforce line endings to prevent script corruption across OS checkouts.

# Default: normalise text files to LF in the repository
* text=auto

# Shell scripts MUST be LF — CRLF breaks the bash shebang on Linux/WSL
*.sh text eol=lf

# Windows launcher scripts use CRLF on Windows
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
